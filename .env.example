# 지도 API 키 (클라이언트 노출됨)
NEXT_PUBLIC_KAKAO_MAP_KEY=
NEXT_PUBLIC_GOOGLE_MAPS_KEY=

# 백오피스 인증 (서버 전용, 프로덕션 편집 시 필요)
# 로그인 비밀번호
ADMIN_PASSWORD=
# 세션 쿠키 서명용 비밀키 (선택, 없으면 ADMIN_PASSWORD로 대체 — 넣는 것을 권장)
ADMIN_SESSION_SECRET=

# GitHub 저장 (프로덕션 편집 시 필요)
# 저장소 Contents 읽기/쓰기 권한이 있는 fine-grained personal access token
GITHUB_TOKEN=
# "owner/repo" 형식 (예: hyeri-leelee/busantrip)
GITHUB_REPO=hyeri-leelee/busantrip
# 커밋 대상 브랜치 (기본 main)
GITHUB_BRANCH=main
